---
import DashboardLayout from '../layouts/DashboardLayout.astro';

const students = [
  { doc: '30.123.456', apellido: 'García',    nombre: 'Lucas',    curso: '3°', div: 'A', turno: 'Mañana',  status: 'ok'      },
  { doc: '31.456.789', apellido: 'Martínez',  nombre: 'Sofía',    curso: '3°', div: 'A', turno: 'Mañana',  status: 'ok'      },
  { doc: '29.876.543', apellido: 'López',     nombre: 'Matías',   curso: '4°', div: 'B', turno: 'Tarde',   status: 'warning' },
  { doc: '32.234.567', apellido: 'Fernández', nombre: 'Valentina',curso: '4°', div: 'B', turno: 'Tarde',   status: 'ok'      },
  { doc: '28.654.321', apellido: 'Rodríguez', nombre: 'Tomás',    curso: '5°', div: 'C', turno: 'Mañana',  status: 'error'   },
  { doc: '33.345.678', apellido: 'González',  nombre: 'Camila',   curso: '5°', div: 'C', turno: 'Mañana',  status: 'ok'      },
  { doc: '30.987.654', apellido: 'Díaz',      nombre: 'Nicolás',  curso: '6°', div: 'A', turno: 'Tarde',   status: 'ok'      },
  { doc: '31.567.890', apellido: 'Torres',    nombre: 'Agustina', curso: '6°', div: 'A', turno: 'Tarde',   status: 'ok'      },
  { doc: '29.234.567', apellido: 'Ruiz',      nombre: 'Franco',   curso: '7°', div: 'B', turno: 'Mañana',  status: 'warning' },
  { doc: '32.678.901', apellido: 'Sánchez',   nombre: 'Micaela',  curso: '7°', div: 'B', turno: 'Mañana',  status: 'ok'      },
];

const statusConfig = {
  ok:      { icon: 'check_circle', classes: 'text-emerald-600', bg: '' },
  warning: { icon: 'warning',      classes: 'text-amber-500',   bg: 'bg-amber-50' },
  error:   { icon: 'error',        classes: 'text-error',       bg: 'bg-error-container/10' },
};

const total   = 1450;
const ok      = 1430;
const warning = 15;
const error   = 5;
---

<DashboardLayout title="Vista Previa" activeItem="imports" searchPlaceholder="Buscar en vista previa...">

  <!-- Breadcrumb -->
  <nav class="flex items-center gap-xs text-on-surface-variant font-label-sm text-label-sm mb-xl flex-wrap">
    <a href="/imports" class="hover:text-primary transition-colors">Importar</a>
    <span class="material-symbols-outlined text-[16px]">chevron_right</span>
    <a href="/imports" class="hover:text-primary transition-colors">Validación</a>
    <span class="material-symbols-outlined text-[16px]">chevron_right</span>
    <a href="/mapping" class="hover:text-primary transition-colors">Mapeo</a>
    <span class="material-symbols-outlined text-[16px]">chevron_right</span>
    <span class="text-primary font-bold">Vista Previa</span>
  </nav>

  <!-- Header -->
  <div class="flex justify-between items-end mb-xl">
    <div>
      <h2 class="font-headline-lg text-headline-lg text-on-surface">Vista Previa de Datos</h2>
      <p class="font-body-md text-body-md text-on-surface-variant">
        Revisá los datos transformados antes de sincronizar con SInIDE.
      </p>
    </div>
  </div>

  <!-- Summary Cards -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-lg mb-xl">
    <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-lg text-center shadow-sm">
      <p class="font-label-sm text-label-sm text-on-surface-variant mb-xs">Total registros</p>
      <p class="font-headline-md text-headline-md text-on-surface">{total.toLocaleString('es-AR')}</p>
    </div>
    <div class="bg-emerald-50 border border-emerald-200 rounded-xl p-lg text-center shadow-sm">
      <p class="font-label-sm text-label-sm text-emerald-800 mb-xs">Listos para enviar</p>
      <div class="flex items-center justify-center gap-xs text-emerald-700">
        <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 1">check_circle</span>
        <p class="font-headline-md text-headline-md">{ok.toLocaleString('es-AR')}</p>
      </div>
    </div>
    <div class="bg-amber-50 border border-amber-200 rounded-xl p-lg text-center shadow-sm">
      <p class="font-label-sm text-label-sm text-amber-800 mb-xs">Con advertencias</p>
      <div class="flex items-center justify-center gap-xs text-amber-600">
        <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 1">warning</span>
        <p class="font-headline-md text-headline-md">{warning}</p>
      </div>
    </div>
    <div class="bg-error-container/30 border border-error-container rounded-xl p-lg text-center shadow-sm">
      <p class="font-label-sm text-label-sm text-on-error-container mb-xs">Con errores</p>
      <div class="flex items-center justify-center gap-xs text-error">
        <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 1">error</span>
        <p class="font-headline-md text-headline-md">{error}</p>
      </div>
    </div>
  </div>

  <!-- Filters bar -->
  <div class="flex items-center justify-between mb-lg">
    <div class="flex gap-sm">
      {['Todos', 'Listos', 'Advertencias', 'Errores'].map((f, i) => (
        <button class:list={[
          'px-md py-xs rounded-lg font-label-sm text-label-sm transition-colors',
          i === 0
            ? 'bg-primary text-white'
            : 'bg-surface-container-lowest border border-outline-variant text-on-surface-variant hover:bg-surface-container-low'
        ]}>
          {f}
        </button>
      ))}
    </div>
    <div class="flex items-center gap-sm text-on-surface-variant">
      <span class="material-symbols-outlined text-[18px]">table_rows</span>
      <span class="font-body-sm text-body-sm">Mostrando 10 de {total.toLocaleString('es-AR')}</span>
    </div>
  </div>

  <!-- Data Table -->
  <div class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden shadow-sm mb-xl">
    <div class="overflow-x-auto">
      <table class="w-full text-left">
        <thead class="bg-surface-container-low border-b border-outline-variant">
          <tr>
            <th class="px-lg py-sm font-label-md text-label-md text-on-surface-variant w-8">#</th>
            <th class="px-lg py-sm font-label-md text-label-md text-on-surface-variant">Documento</th>
            <th class="px-lg py-sm font-label-md text-label-md text-on-surface-variant">Apellido</th>
            <th class="px-lg py-sm font-label-md text-label-md text-on-surface-variant">Nombre</th>
            <th class="px-lg py-sm font-label-md text-label-md text-on-surface-variant">Curso</th>
            <th class="px-lg py-sm font-label-md text-label-md text-on-surface-variant">División</th>
            <th class="px-lg py-sm font-label-md text-label-md text-on-surface-variant">Turno</th>
            <th class="px-lg py-sm font-label-md text-label-md text-on-surface-variant">Estado</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-outline-variant">
          {students.map((s, i) => {
            const cfg = statusConfig[s.status as keyof typeof statusConfig];
            return (
              <tr class:list={['transition-colors hover:bg-surface-container-low/60', cfg.bg]}>
                <td class="px-lg py-md font-code text-code text-on-surface-variant">{i + 1}</td>
                <td class="px-lg py-md font-code text-code text-on-surface">{s.doc}</td>
                <td class="px-lg py-md font-label-md text-label-md text-on-surface font-semibold">{s.apellido}</td>
                <td class="px-lg py-md font-label-md text-label-md text-on-surface">{s.nombre}</td>
                <td class="px-lg py-md">
                  <span class="px-sm py-xs bg-primary-fixed text-on-primary-fixed rounded font-label-sm text-label-sm">
                    {s.curso}
                  </span>
                </td>
                <td class="px-lg py-md font-body-sm text-body-sm text-on-surface">{s.div}</td>
                <td class="px-lg py-md font-body-sm text-body-sm text-on-surface-variant">{s.turno}</td>
                <td class="px-lg py-md">
                  <span class:list={['material-symbols-outlined text-[20px]', cfg.classes]}
                    style="font-variation-settings: 'FILL' 1"
                    title={s.status}>
                    {cfg.icon}
                  </span>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>

    <!-- Table Footer -->
    <div class="px-lg py-md border-t border-outline-variant bg-surface-container-low flex justify-between items-center">
      <p class="font-body-sm text-body-sm text-on-surface-variant">
        Página 1 de 145
      </p>
      <div class="flex gap-sm">
        <button class="px-md py-xs border border-outline-variant rounded-lg font-label-sm text-label-sm text-on-surface-variant hover:bg-white transition-colors" disabled>
          ← Anterior
        </button>
        <button class="px-md py-xs bg-primary text-white rounded-lg font-label-sm text-label-sm hover:opacity-90 transition-colors">
          Siguiente →
        </button>
      </div>
    </div>
  </div>

  <!-- Warning notice -->
  <div class="bg-amber-50 border border-amber-200 rounded-xl p-lg flex items-start gap-md mb-xl">
    <span class="material-symbols-outlined text-amber-500 shrink-0 mt-0.5" style="font-variation-settings: 'FILL' 1">info</span>
    <div>
      <p class="font-label-md text-label-md text-amber-800 font-bold mb-xs">Antes de sincronizar</p>
      <p class="font-body-sm text-body-sm text-amber-700">
        Hay <strong>{warning} registros con advertencias</strong> y <strong>{error} con errores</strong>.
        Los errores serán omitidos en la sincronización. Las advertencias se enviarán igualmente.
        Podés volver a corregirlos o continuar.
      </p>
    </div>
  </div>

  <!-- Footer Actions -->
  <div class="flex justify-between items-center">
    <a href="/mapping" class="px-lg py-md border border-outline-variant text-on-surface-variant rounded-lg font-label-md text-label-md flex items-center gap-sm hover:bg-surface-container-low transition-colors">
      <span class="material-symbols-outlined">arrow_back</span>
      Volver al Mapeo
    </a>
    <div class="flex gap-md items-center">
      <p class="font-body-sm text-body-sm text-on-surface-variant">
        <span class="font-bold text-on-surface">{ok.toLocaleString('es-AR')} registros</span> listos para sincronizar
      </p>
      <a
        href="/sync"
        class="bg-primary text-on-primary px-2xl py-md rounded-lg font-headline-sm text-headline-sm shadow-lg hover:shadow-xl hover:scale-[1.02] active:scale-[0.98] transition-all flex items-center gap-md"
      >
        Iniciar Sincronización
        <span class="material-symbols-outlined">sync</span>
      </a>
    </div>
  </div>

</DashboardLayout>