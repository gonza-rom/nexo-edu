---
import DashboardLayout from '../layouts/DashboardLayout.astro';

const syncId = 'SYNC-2024-0314-001';
const fecha   = '14 de marzo de 2024, 14:32 hs';

const stats = {
  procesados: 1520,
  enviados:   1485,
  errores:    35,
  duracion:   '2m 18s',
  ahorro:     18,
};
---

<DashboardLayout title="Sincronización Completada" activeItem="imports" searchPlaceholder="Buscar sincronizaciones...">

  <!-- Breadcrumb -->
  <nav class="flex items-center gap-xs text-on-surface-variant font-label-sm text-label-sm mb-xl">
    <a href="/imports" class="hover:text-primary transition-colors">Importar</a>
    <span class="material-symbols-outlined text-[16px]">chevron_right</span>
    <a href="/sync" class="hover:text-primary transition-colors">Sincronización</a>
    <span class="material-symbols-outlined text-[16px]">chevron_right</span>
    <span class="text-primary font-bold">Resultado</span>
  </nav>

  <!-- Hero de éxito -->
  <section class="relative overflow-hidden bg-white border border-outline-variant rounded-2xl p-2xl mb-lg shadow-sm">

    <!-- Fondo decorativo -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="absolute -top-16 -right-16 w-64 h-64 rounded-full bg-primary-fixed opacity-40"></div>
      <div class="absolute -bottom-10 -left-10 w-48 h-48 rounded-full bg-surface-container-highest opacity-60"></div>
    </div>

    <div class="relative z-10 flex flex-col lg:flex-row items-center lg:items-start gap-xl">

      <!-- Ícono animado -->
      <div class="shrink-0">
        <div class="success-ring w-24 h-24 rounded-full bg-primary-fixed flex items-center justify-center shadow-lg">
          <span class="material-symbols-outlined text-primary text-[48px] success-check"
                style="font-variation-settings: 'FILL' 1">
            check_circle
          </span>
        </div>
      </div>

      <!-- Texto principal -->
      <div class="flex-1 text-center lg:text-left">
        <div class="inline-flex items-center gap-sm px-md py-xs bg-emerald-50 border border-emerald-200 rounded-full mb-md">
          <span class="w-2 h-2 rounded-full bg-emerald-500 inline-block"></span>
          <span class="font-label-sm text-label-sm text-emerald-700 font-bold">Sincronización exitosa</span>
        </div>
        <h2 class="font-headline-lg text-headline-lg text-on-surface mb-xs">
          ¡Los datos fueron enviados a SInIDE!
        </h2>
        <p class="font-body-md text-body-md text-on-surface-variant max-w-lg">
          El proceso de integración finalizó correctamente. Los registros de estudiantes ya están disponibles en el sistema central.
        </p>
        <div class="flex flex-wrap gap-sm mt-md">
          <span class="font-label-sm text-label-sm text-on-surface-variant flex items-center gap-xs">
            <span class="material-symbols-outlined text-[16px]">tag</span>
            ID: {syncId}
          </span>
          <span class="text-on-surface-variant">·</span>
          <span class="font-label-sm text-label-sm text-on-surface-variant flex items-center gap-xs">
            <span class="material-symbols-outlined text-[16px]">schedule</span>
            {fecha}
          </span>
          <span class="text-on-surface-variant">·</span>
          <span class="font-label-sm text-label-sm text-on-surface-variant flex items-center gap-xs">
            <span class="material-symbols-outlined text-[16px]">timer</span>
            Duración: {stats.duracion}
          </span>
        </div>
      </div>

      <!-- ROI badge -->
      <div class="shrink-0 bg-primary text-white rounded-xl p-lg text-center min-w-[140px] shadow-md relative overflow-hidden">
        <div class="absolute -bottom-3 -right-3 opacity-10 pointer-events-none">
          <span class="material-symbols-outlined text-[80px]">bolt</span>
        </div>
        <p class="font-label-sm text-label-sm text-primary-fixed opacity-80 uppercase tracking-widest mb-xs">Ahorro</p>
        <p class="text-[36px] font-bold leading-none">{stats.ahorro}</p>
        <p class="font-label-md text-label-md text-primary-fixed mt-xs">horas</p>
        <p class="font-body-sm text-body-sm text-primary-fixed opacity-60 mt-sm">vs. carga manual</p>
      </div>

    </div>
  </section>

  <!-- Stats principales -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-md mb-lg">
    <div class="bg-surface border border-outline-variant rounded-xl p-lg text-center shadow-sm">
      <p class="font-label-sm text-label-sm text-on-surface-variant mb-xs">Total procesados</p>
      <p class="font-headline-md text-headline-md text-on-surface counter" data-target="{stats.procesados}">
        {stats.procesados.toLocaleString('es-AR')}
      </p>
    </div>
    <div class="bg-emerald-50 border border-emerald-200 rounded-xl p-lg text-center shadow-sm">
      <p class="font-label-sm text-label-sm text-emerald-800 mb-xs">Enviados exitosamente</p>
      <div class="flex items-center justify-center gap-xs text-emerald-700">
        <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 1">check_circle</span>
        <p class="font-headline-md text-headline-md">{stats.enviados.toLocaleString('es-AR')}</p>
      </div>
    </div>
    <div class="bg-error-container/20 border border-error-container rounded-xl p-lg text-center shadow-sm">
      <p class="font-label-sm text-label-sm text-on-error-container mb-xs">Con errores</p>
      <div class="flex items-center justify-center gap-xs text-error">
        <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 1">error</span>
        <p class="font-headline-md text-headline-md">{stats.errores}</p>
      </div>
    </div>
    <div class="bg-surface border border-outline-variant rounded-xl p-lg text-center shadow-sm">
      <p class="font-label-sm text-label-sm text-on-surface-variant mb-xs">Tasa de éxito</p>
      <p class="font-headline-md text-headline-md text-primary">
        {Math.round((stats.enviados / stats.procesados) * 100)}%
      </p>
    </div>
  </div>

  <!-- Barra visual de resultado -->
  <div class="bg-surface border border-outline-variant rounded-xl p-lg mb-lg shadow-sm">
    <div class="flex justify-between items-center mb-sm">
      <span class="font-label-md text-label-md text-on-surface font-bold">Desglose de resultados</span>
      <span class="font-label-sm text-label-sm text-on-surface-variant">{stats.procesados.toLocaleString('es-AR')} registros totales</span>
    </div>
    <div class="w-full h-4 rounded-full overflow-hidden flex">
      <div
        class="h-full bg-emerald-500 transition-all duration-1000"
        style={`width: ${Math.round((stats.enviados / stats.procesados) * 100)}%`}
        title={`${stats.enviados} enviados`}
      ></div>
      <div
        class="h-full bg-error/60"
        style={`width: ${Math.round((stats.errores / stats.procesados) * 100)}%`}
        title={`${stats.errores} con errores`}
      ></div>
    </div>
    <div class="flex gap-lg mt-sm">
      <div class="flex items-center gap-xs">
        <span class="w-3 h-3 rounded-full bg-emerald-500 shrink-0"></span>
        <span class="font-body-sm text-body-sm text-on-surface-variant">Enviados ({stats.enviados.toLocaleString('es-AR')})</span>
      </div>
      <div class="flex items-center gap-xs">
        <span class="w-3 h-3 rounded-full bg-error/60 shrink-0"></span>
        <span class="font-body-sm text-body-sm text-on-surface-variant">Con errores ({stats.errores})</span>
      </div>
    </div>
  </div>

  <!-- Grid: errores + próximos pasos -->
  <div class="grid grid-cols-12 gap-lg mb-xl">

    <!-- Errores detallados -->
    <div class="col-span-12 lg:col-span-7 bg-surface border border-outline-variant rounded-xl overflow-hidden shadow-sm">
      <div class="flex justify-between items-center px-lg py-md border-b border-outline-variant bg-surface-container-lowest">
        <div class="flex items-center gap-sm">
          <span class="material-symbols-outlined text-error text-[20px]">warning</span>
          <h3 class="font-headline-sm text-headline-sm text-on-surface">Registros con errores</h3>
          <span class="px-sm py-xs bg-error-container text-on-error-container rounded font-label-sm text-label-sm">{stats.errores}</span>
        </div>
        <button class="text-primary font-label-md text-label-md flex items-center gap-xs hover:underline transition-all">
          <span class="material-symbols-outlined text-[18px]">download</span>
          Descargar log
        </button>
      </div>
      <div class="divide-y divide-outline-variant">
        {[
          { id: 'STU-8823', nombre: 'Rodríguez, Tomás',   motivo: 'Email duplicado',         fila: 5  },
          { id: 'STU-0045', nombre: 'Perez, Juan',         motivo: 'DNI duplicado',            fila: 45 },
          { id: 'STU-0120', nombre: 'Garcia Lopez, Maria', motivo: 'Formato de nombre inválido', fila: 120 },
        ].map((r) => (
          <div class="flex items-center justify-between px-lg py-md hover:bg-error-container/5 transition-colors">
            <div class="flex items-center gap-md">
              <div class="w-9 h-9 rounded-lg bg-error-container flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-on-error-container text-[18px]">person_off</span>
              </div>
              <div>
                <p class="font-label-md text-label-md text-on-surface">{r.nombre}</p>
                <p class="font-body-sm text-body-sm text-on-surface-variant">ID: {r.id} · Fila {r.fila}</p>
              </div>
            </div>
            <div class="text-right">
              <span class="inline-flex items-center gap-xs px-sm py-xs bg-error-container/30 text-on-error-container rounded font-label-sm text-label-sm">
                <span class="material-symbols-outlined text-[14px]">error</span>
                {r.motivo}
              </span>
            </div>
          </div>
        ))}
      </div>
      <div class="px-lg py-md border-t border-outline-variant bg-surface-container-lowest">
        <p class="font-body-sm text-body-sm text-on-surface-variant italic">
          Estos registros fueron omitidos en la sincronización. Corregí los datos y reimportá solo los errores.
        </p>
      </div>
    </div>

    <!-- Panel derecho -->
    <div class="col-span-12 lg:col-span-5 space-y-md">

      <!-- Próximos pasos -->
      <div class="bg-surface border border-outline-variant rounded-xl p-lg shadow-sm">
        <h4 class="font-label-md text-label-md font-bold text-on-surface uppercase tracking-wider mb-md">Próximos pasos</h4>
        <div class="space-y-sm">
          <div class="flex items-start gap-md p-md rounded-lg bg-primary-fixed/40 border border-primary/10">
            <div class="w-8 h-8 rounded-full bg-primary text-white flex items-center justify-center shrink-0 font-bold text-label-sm">1</div>
            <div>
              <p class="font-label-md text-label-md text-on-surface">Corregir registros con errores</p>
              <p class="font-body-sm text-body-sm text-on-surface-variant">Descargá el log, corregí los {stats.errores} registros y reimportá.</p>
            </div>
          </div>
          <div class="flex items-start gap-md p-md rounded-lg bg-surface-container-low border border-outline-variant">
            <div class="w-8 h-8 rounded-full bg-surface-container text-on-surface-variant flex items-center justify-center shrink-0 font-bold text-label-sm">2</div>
            <div>
              <p class="font-label-md text-label-md text-on-surface">Verificar en SInIDE</p>
              <p class="font-body-sm text-body-sm text-on-surface-variant">Confirmá que los registros aparecen correctamente en el sistema.</p>
            </div>
          </div>
          <div class="flex items-start gap-md p-md rounded-lg bg-surface-container-low border border-outline-variant">
            <div class="w-8 h-8 rounded-full bg-surface-container text-on-surface-variant flex items-center justify-center shrink-0 font-bold text-label-sm">3</div>
            <div>
              <p class="font-label-md text-label-md text-on-surface">Guardar configuración de mapeo</p>
              <p class="font-body-sm text-body-sm text-on-surface-variant">Reutilizá este mapeo en la próxima importación mensual.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Badge seguridad -->
      <div class="bg-secondary rounded-xl p-lg flex items-center gap-md shadow-md">
        <div class="w-10 h-10 bg-primary-fixed rounded-full flex items-center justify-center text-primary shrink-0">
          <span class="material-symbols-outlined">verified_user</span>
        </div>
        <div>
          <p class="font-label-md text-label-md text-white font-bold">Datos sincronizados de forma segura</p>
          <p class="font-body-sm text-body-sm text-secondary-fixed-dim/70">TLS 1.3 · Auditoría registrada · {fecha}</p>
        </div>
      </div>

    </div>
  </div>

  <!-- Footer Actions -->
  <div class="flex flex-col md:flex-row justify-between items-center gap-md">
    <div class="flex gap-md">
      <a
        href="/history"
        class="px-lg py-md border border-outline-variant text-on-surface-variant rounded-lg font-label-md text-label-md flex items-center gap-sm hover:bg-surface-container-low transition-colors"
      >
        <span class="material-symbols-outlined">manage_search</span>
        Ver Historial Completo
      </a>
      <button
        class="px-lg py-md border border-outline-variant text-on-surface-variant rounded-lg font-label-md text-label-md flex items-center gap-sm hover:bg-surface-container-low transition-colors"
      >
        <span class="material-symbols-outlined">description</span>
        Descargar Reporte PDF
      </button>
    </div>
    <a
      href="/imports"
      class="bg-primary text-on-primary px-2xl py-md rounded-lg font-headline-sm text-headline-sm shadow-lg hover:shadow-xl hover:scale-[1.02] active:scale-[0.98] transition-all flex items-center gap-md"
    >
      <span class="material-symbols-outlined">add_circle</span>
      Nueva Importación
    </a>
  </div>

</DashboardLayout>

<style>
  /* Animación de entrada del check */
  @keyframes pop-in {
    0%   { transform: scale(0.4); opacity: 0; }
    70%  { transform: scale(1.15); }
    100% { transform: scale(1); opacity: 1; }
  }
  @keyframes ring-pulse {
    0%   { box-shadow: 0 0 0 0 rgba(var(--primary-rgb, 83,74,183), 0.4); }
    70%  { box-shadow: 0 0 0 16px rgba(var(--primary-rgb, 83,74,183), 0); }
    100% { box-shadow: 0 0 0 0 rgba(var(--primary-rgb, 83,74,183), 0); }
  }

  .success-check {
    animation: pop-in 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) 0.2s both;
  }
  .success-ring {
    animation: ring-pulse 1s ease-out 0.5s;
  }
</style>