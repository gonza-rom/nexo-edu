---
import DashboardLayout from '../layouts/DashboardLayout.astro';

// Columnas detectadas en el archivo subido
const sourceColumns = [
  'apellido_alumno',
  'nombre_alumno',
  'nro_documento',
  'tipo_doc',
  'fecha_nacimiento',
  'grado',
  'division',
  'turno',
  'email_tutor',
  'telefono',
];

// Campos destino del sistema SInIDE
const targetFields = [
  { value: '',                  label: '— Sin mapear —' },
  { value: 'apellido',          label: 'Apellido'       },
  { value: 'nombre',            label: 'Nombre'         },
  { value: 'documento',         label: 'Documento (DNI)'},
  { value: 'tipo_documento',    label: 'Tipo Documento' },
  { value: 'fecha_nac',         label: 'Fecha Nacimiento'},
  { value: 'curso',             label: 'Curso'          },
  { value: 'division',          label: 'División'       },
  { value: 'turno',             label: 'Turno'          },
  { value: 'email',             label: 'Email Tutor'    },
  { value: 'telefono',          label: 'Teléfono'       },
];

// Sugerencias automáticas basadas en nombre de columna
const autoMap: Record<string, string> = {
  apellido_alumno:  'apellido',
  nombre_alumno:    'nombre',
  nro_documento:    'documento',
  tipo_doc:         'tipo_documento',
  fecha_nacimiento: 'fecha_nac',
  grado:            'curso',
  division:         'division',
  turno:            'turno',
  email_tutor:      'email',
  telefono:         'telefono',
};
---

<DashboardLayout title="Mapeo de Campos" activeItem="imports" searchPlaceholder="Buscar columnas...">

  <!-- Breadcrumb -->
  <nav class="flex items-center gap-xs text-on-surface-variant font-label-sm text-label-sm mb-xl">
    <a href="/imports" class="hover:text-primary transition-colors">Importar</a>
    <span class="material-symbols-outlined text-[16px]">chevron_right</span>
    <a href="/imports" class="hover:text-primary transition-colors">Validación</a>
    <span class="material-symbols-outlined text-[16px]">chevron_right</span>
    <span class="text-primary font-bold">Mapeo de Campos</span>
  </nav>

  <!-- Header -->
  <div class="flex justify-between items-end mb-xl">
    <div>
      <h2 class="font-headline-lg text-headline-lg text-on-surface">Mapeo de Campos</h2>
      <p class="font-body-md text-body-md text-on-surface-variant">
        Asociá cada columna de tu archivo con el campo correspondiente en SInIDE.
      </p>
    </div>
    <div class="flex gap-md">
      <button id="btn-auto" class="px-lg py-sm border border-primary text-primary rounded-lg font-label-md text-label-md flex items-center gap-sm hover:bg-primary/5 transition-colors">
        <span class="material-symbols-outlined text-[18px]">auto_fix_high</span>
        Mapeo Automático
      </button>
      <button id="btn-save" class="px-lg py-sm border border-outline-variant text-on-surface-variant rounded-lg font-label-md text-label-md flex items-center gap-sm hover:bg-surface-container-low transition-colors">
        <span class="material-symbols-outlined text-[18px]">save</span>
        Guardar Configuración
      </button>
    </div>
  </div>

  <div class="grid grid-cols-12 gap-lg">

    <!-- Mapper Main -->
    <div class="col-span-12 lg:col-span-8">
      <div class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden shadow-sm">

        <!-- Table header -->
        <div class="grid grid-cols-2 gap-0 bg-surface-container-low border-b border-outline-variant px-lg py-sm">
          <div class="flex items-center gap-sm">
            <span class="material-symbols-outlined text-[18px] text-on-surface-variant">table_chart</span>
            <span class="font-label-md text-label-md font-bold text-on-surface-variant uppercase tracking-wider">
              Columna del Archivo
            </span>
          </div>
          <div class="flex items-center gap-sm pl-lg">
            <span class="material-symbols-outlined text-[18px] text-primary">account_tree</span>
            <span class="font-label-md text-label-md font-bold text-on-surface-variant uppercase tracking-wider">
              Campo en SInIDE
            </span>
          </div>
        </div>

        <!-- Rows -->
        <div class="divide-y divide-outline-variant" id="mapping-rows">
          {sourceColumns.map((col, i) => {
            const mapped = autoMap[col] ?? '';
            const isMapped = mapped !== '';
            return (
              <div class="grid grid-cols-2 gap-0 items-center hover:bg-surface-container-low/50 transition-colors" data-row>
                <!-- Source -->
                <div class="px-lg py-md flex items-center gap-md border-r border-outline-variant">
                  <div class="w-8 h-8 rounded bg-surface-container flex items-center justify-center shrink-0">
                    <span class="font-code text-code text-on-surface-variant font-bold">{i + 1}</span>
                  </div>
                  <div>
                    <p class="font-code text-code text-on-surface">{col}</p>
                    <p class="font-body-sm text-body-sm text-on-surface-variant">
                      {i === 0 ? 'ej: García' : i === 1 ? 'ej: Juan' : i === 2 ? 'ej: 30123456' : 'Texto'}
                    </p>
                  </div>
                </div>
                <!-- Target -->
                <div class="px-lg py-md flex items-center gap-md">
                  <span class:list={[
                    'material-symbols-outlined text-[20px] shrink-0',
                    isMapped ? 'text-primary' : 'text-outline-variant'
                  ]}>
                    {isMapped ? 'arrow_right_alt' : 'remove'}
                  </span>
                  <select
                    class:list={[
                      'flex-1 rounded-lg px-md py-sm font-label-md text-label-md border outline-none focus:ring-2 focus:ring-primary/20 transition-all cursor-pointer',
                      isMapped
                        ? 'border-primary/40 bg-primary-fixed/30 text-on-surface'
                        : 'border-outline-variant bg-white text-on-surface-variant'
                    ]}
                    data-select
                  >
                    {targetFields.map((f) => (
                      <option value={f.value} selected={f.value === mapped}>
                        {f.label}
                      </option>
                    ))}
                  </select>
                  {isMapped && (
                    <span class="w-2 h-2 rounded-full bg-emerald-500 shrink-0"></span>
                  )}
                </div>
              </div>
            );
          })}
        </div>

      </div>
    </div>

    <!-- Right panel -->
    <div class="col-span-12 lg:col-span-4 space-y-lg">

      <!-- Summary -->
      <div class="bg-surface-container rounded-xl p-lg space-y-md">
        <h4 class="font-label-md text-label-md font-bold text-on-surface uppercase tracking-wider">Resumen de Mapeo</h4>
        <div class="space-y-sm">
          <div class="flex justify-between items-center p-sm bg-white rounded-lg border border-outline-variant">
            <span class="font-body-sm text-body-sm text-on-surface-variant">Total de columnas</span>
            <span class="font-bold text-label-md text-on-surface">{sourceColumns.length}</span>
          </div>
          <div class="flex justify-between items-center p-sm bg-white rounded-lg border border-emerald-200">
            <span class="font-body-sm text-body-sm text-on-surface-variant">Campos mapeados</span>
            <span class="px-2 py-1 bg-emerald-100 text-emerald-800 rounded font-bold text-label-sm" id="mapped-count">
              {Object.keys(autoMap).length}
            </span>
          </div>
          <div class="flex justify-between items-center p-sm bg-white rounded-lg border border-outline-variant">
            <span class="font-body-sm text-body-sm text-on-surface-variant">Sin mapear</span>
            <span class="px-2 py-1 bg-surface-container text-on-surface-variant rounded font-bold text-label-sm" id="unmapped-count">
              {sourceColumns.length - Object.keys(autoMap).length}
            </span>
          </div>
        </div>

        <!-- Progress -->
        <div class="pt-sm border-t border-outline-variant">
          <div class="flex justify-between mb-2">
            <span class="font-label-sm text-label-sm text-on-surface-variant">Cobertura</span>
            <span class="font-label-sm text-label-sm font-bold text-primary" id="coverage-pct">
              {Math.round((Object.keys(autoMap).length / sourceColumns.length) * 100)}%
            </span>
          </div>
          <div class="w-full bg-outline-variant rounded-full h-1.5">
            <div
              class="bg-primary h-1.5 rounded-full transition-all duration-300"
              id="coverage-bar"
              style={`width: ${Math.round((Object.keys(autoMap).length / sourceColumns.length) * 100)}%`}
            ></div>
          </div>
        </div>
      </div>

      <!-- Tip card -->
      <div class="bg-primary-fixed rounded-xl p-lg space-y-sm border border-primary/20">
        <div class="flex items-center gap-sm">
          <span class="material-symbols-outlined text-primary">lightbulb</span>
          <h4 class="font-label-md text-label-md font-bold text-on-surface">Tip</h4>
        </div>
        <p class="font-body-sm text-body-sm text-on-surface-variant">
          Usá <strong>Mapeo Automático</strong> para que NexoEDU detecte los campos comunes por nombre.
          Podés guardar esta configuración para reutilizarla en próximas importaciones.
        </p>
      </div>

      <!-- Required fields -->
      <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-lg space-y-sm">
        <h4 class="font-label-md text-label-md font-bold text-on-surface">Campos obligatorios SInIDE</h4>
        <div class="space-y-xs">
          {['Apellido', 'Nombre', 'Documento (DNI)', 'Curso', 'División'].map((f) => (
            <div class="flex items-center gap-sm">
              <span class="material-symbols-outlined text-emerald-600 text-[16px]" style="font-variation-settings: 'FILL' 1">check_circle</span>
              <span class="font-body-sm text-body-sm text-on-surface">{f}</span>
            </div>
          ))}
        </div>
      </div>

    </div>

  </div>

  <!-- Footer Actions -->
  <div class="mt-xl flex justify-between items-center">
    <a href="/imports" class="px-lg py-md border border-outline-variant text-on-surface-variant rounded-lg font-label-md text-label-md flex items-center gap-sm hover:bg-surface-container-low transition-colors">
      <span class="material-symbols-outlined">arrow_back</span>
      Volver a Validación
    </a>
    <a href="/preview" class="bg-primary text-on-primary px-2xl py-md rounded-lg font-headline-sm text-headline-sm shadow-lg hover:shadow-xl hover:scale-[1.02] active:scale-[0.98] transition-all flex items-center gap-md">
      Ver Vista Previa
      <span class="material-symbols-outlined">arrow_forward</span>
    </a>
  </div>

</DashboardLayout>

<script>
  const total = document.querySelectorAll('[data-select]').length;

  function updateCounts() {
    let mapped = 0;
    document.querySelectorAll<HTMLSelectElement>('[data-select]').forEach((sel) => {
      const row = sel.closest('[data-row]');
      const arrow = row?.querySelector('.material-symbols-outlined');
      const dot = row?.querySelector('.w-2.h-2.rounded-full');

      if (sel.value !== '') {
        mapped++;
        sel.classList.remove('border-outline-variant', 'bg-white', 'text-on-surface-variant');
        sel.classList.add('border-primary/40', 'bg-primary-fixed/30', 'text-on-surface');
        if (arrow) { arrow.textContent = 'arrow_right_alt'; arrow.classList.remove('text-outline-variant'); arrow.classList.add('text-primary'); }
      } else {
        sel.classList.add('border-outline-variant', 'bg-white', 'text-on-surface-variant');
        sel.classList.remove('border-primary/40', 'bg-primary-fixed/30', 'text-on-surface');
        if (arrow) { arrow.textContent = 'remove'; arrow.classList.add('text-outline-variant'); arrow.classList.remove('text-primary'); }
      }
    });

    const pct = Math.round((mapped / total) * 100);
    const mappedEl = document.getElementById('mapped-count');
    const unmappedEl = document.getElementById('unmapped-count');
    const pctEl = document.getElementById('coverage-pct');
    const barEl = document.getElementById('coverage-bar');
    if (mappedEl) mappedEl.textContent = String(mapped);
    if (unmappedEl) unmappedEl.textContent = String(total - mapped);
    if (pctEl) pctEl.textContent = pct + '%';
    if (barEl) barEl.style.width = pct + '%';
  }

  document.querySelectorAll<HTMLSelectElement>('[data-select]').forEach((sel) => {
    sel.addEventListener('change', updateCounts);
  });

  document.getElementById('btn-auto')?.addEventListener('click', () => {
    const autoValues = [
      'apellido','nombre','documento','tipo_documento',
      'fecha_nac','curso','division','turno','email','telefono'
    ];
    document.querySelectorAll<HTMLSelectElement>('[data-select]').forEach((sel, i) => {
      sel.value = autoValues[i] ?? '';
    });
    updateCounts();
  });

  document.getElementById('btn-save')?.addEventListener('click', () => {
    const btn = document.getElementById('btn-save');
    if (btn) {
      btn.textContent = '';
      btn.innerHTML = '<span class="material-symbols-outlined text-[18px]">check</span> Guardado';
      btn.classList.add('text-emerald-600', 'border-emerald-300');
      setTimeout(() => {
        btn.innerHTML = '<span class="material-symbols-outlined text-[18px]">save</span> Guardar Configuración';
        btn.classList.remove('text-emerald-600', 'border-emerald-300');
      }, 2000);
    }
  });
</script>