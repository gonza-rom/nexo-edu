---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Importar Datos" activeItem="imports" searchPlaceholder="Buscar importaciones...">

  <!-- Breadcrumb + Header -->
  <div class="flex justify-between items-end mb-xl">
    <div>
      <nav class="flex items-center gap-xs text-on-surface-variant mb-xs">
        <span class="font-label-sm text-label-sm">Importar</span>
        <span class="material-symbols-outlined text-[16px]">chevron_right</span>
        <span class="font-label-sm text-label-sm text-primary font-bold">Nueva Validación</span>
      </nav>
      <h2 class="font-headline-lg text-headline-lg text-on-surface">Importación de Datos</h2>
    </div>
  </div>

  <!-- Bento Grid -->
  <div class="grid grid-cols-12 gap-lg">

    <!-- Left: Drop zone + file card -->
    <section class="col-span-12 lg:col-span-8 space-y-lg">

      <!-- Drop Zone -->
      <div
        id="drop-zone"
        class="bg-white/80 backdrop-blur-sm border-2 border-dashed border-outline-variant rounded-xl p-xl flex flex-col items-center justify-center text-center group transition-all hover:border-primary hover:bg-surface-container-low cursor-pointer"
      >
        <div class="w-16 h-16 rounded-full bg-primary-fixed flex items-center justify-center mb-md group-hover:scale-110 transition-transform">
          <span class="material-symbols-outlined text-primary text-[32px]">cloud_upload</span>
        </div>
        <h3 class="font-headline-sm text-headline-sm text-on-surface mb-xs">Cargar archivos de datos</h3>
        <p class="font-body-md text-body-md text-on-surface-variant max-w-sm mx-auto mb-lg">
          Arrastrá y soltá tus archivos Excel (.xlsx) o CSV aquí para iniciar el proceso de integración.
        </p>
        <div class="flex gap-md">
          <button class="px-lg py-sm bg-primary text-on-primary rounded-lg font-label-md text-label-md flex items-center gap-sm hover:opacity-90 transition-opacity">
            <span class="material-symbols-outlined text-[20px]">add</span>
            Seleccionar Archivo
          </button>
          <button class="px-lg py-sm bg-white border border-outline-variant text-on-surface-variant rounded-lg font-label-md text-label-md hover:bg-surface-container-low transition-colors">
            Plantilla Ejemplo
          </button>
        </div>
      </div>

      <!-- Uploaded File Card -->
      <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-lg flex items-center justify-between shadow-sm">
        <div class="flex items-center gap-lg">
          <div class="w-12 h-12 bg-emerald-100 rounded-lg flex items-center justify-center">
            <span class="material-symbols-outlined text-emerald-700">description</span>
          </div>
          <div>
            <h4 class="font-label-md text-label-md font-bold text-on-surface">Estudiantes_Marzo_2024.xlsx</h4>
            <p class="font-body-sm text-body-sm text-on-surface-variant">2.4MB · 1,450 registros detectados</p>
          </div>
        </div>
        <div class="flex items-center gap-md">
          <span class="px-sm py-xs bg-emerald-50 text-emerald-700 border border-emerald-200 rounded font-label-sm text-label-sm">
            Carga completa
          </span>
          <button class="bg-primary text-on-primary px-lg py-sm rounded-lg font-label-md text-label-md flex items-center gap-sm hover:shadow-md transition-all">
            <span class="material-symbols-outlined text-[18px]">verified</span>
            Validar Datos
          </button>
        </div>
      </div>

    </section>

    <!-- Right: Stats + guide -->
    <section class="col-span-12 lg:col-span-4 space-y-lg">

      <!-- Validation Status -->
      <div class="bg-surface-container rounded-xl p-lg space-y-md">
        <h4 class="font-label-md text-label-md font-bold text-on-surface uppercase tracking-wider">Estado de Validación</h4>
        <div class="space-y-sm">
          <div class="flex justify-between items-center p-sm bg-white rounded-lg border border-outline-variant">
            <span class="font-body-sm text-body-sm text-on-surface-variant">Errores Críticos</span>
            <span class="px-2 py-1 bg-error-container text-on-error-container rounded font-bold text-label-sm">01</span>
          </div>
          <div class="flex justify-between items-center p-sm bg-white rounded-lg border border-outline-variant">
            <span class="font-body-sm text-body-sm text-on-surface-variant">Advertencias</span>
            <span class="px-2 py-1 bg-tertiary-fixed text-on-tertiary-fixed-variant rounded font-bold text-label-sm">01</span>
          </div>
          <div class="flex justify-between items-center p-sm bg-white rounded-lg border border-outline-variant">
            <span class="font-body-sm text-body-sm text-on-surface-variant">Registros Válidos</span>
            <span class="px-2 py-1 bg-emerald-100 text-emerald-800 rounded font-bold text-label-sm">1,448</span>
          </div>
        </div>
        <div class="pt-sm border-t border-outline-variant">
          <div class="flex justify-between mb-2">
            <span class="font-label-sm text-label-sm text-on-surface-variant">Progreso de Validación</span>
            <span class="font-label-sm text-label-sm font-bold text-primary">100%</span>
          </div>
          <div class="w-full bg-outline-variant rounded-full h-1.5">
            <div class="bg-primary h-1.5 rounded-full" style="width: 100%"></div>
          </div>
        </div>
      </div>

      <!-- Guide Card -->
      <div class="relative overflow-hidden rounded-xl h-40 group cursor-pointer shadow-md bg-secondary">
        <div class="absolute inset-0 bg-gradient-to-br from-secondary to-primary opacity-90"></div>
        <div class="absolute inset-0 flex flex-col justify-between p-lg">
          <span class="material-symbols-outlined text-primary-fixed text-[32px]">menu_book</span>
          <div>
            <p class="text-white font-label-md text-label-md font-bold">Guía de Importación</p>
            <p class="text-white/70 font-body-sm text-body-sm">Aprendé a mapear campos personalizados</p>
          </div>
        </div>
      </div>

    </section>

    <!-- Validation Table -->
    <section class="col-span-12">
      <div class="bg-white rounded-xl border border-outline-variant overflow-hidden">
        <div class="px-lg py-md border-b border-outline-variant flex justify-between items-center bg-surface-container-lowest">
          <h3 class="font-headline-sm text-headline-sm text-on-surface">Validación de Datos</h3>
          <button class="text-primary font-label-md text-label-md flex items-center gap-xs hover:underline">
            <span class="material-symbols-outlined text-[18px]">download</span>
            Descargar Reporte (PDF)
          </button>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead class="bg-surface-container-low border-b border-outline-variant">
              <tr>
                <th class="px-lg py-sm font-label-md text-label-md text-on-surface-variant">Fila</th>
                <th class="px-lg py-sm font-label-md text-label-md text-on-surface-variant">Entidad / Estudiante</th>
                <th class="px-lg py-sm font-label-md text-label-md text-on-surface-variant">Tipo</th>
                <th class="px-lg py-sm font-label-md text-label-md text-on-surface-variant">Descripción</th>
                <th class="px-lg py-sm font-label-md text-label-md text-on-surface-variant">Recomendación</th>
                <th class="px-lg py-sm font-label-md text-label-md text-on-surface-variant">Acción</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant">
              <tr class="hover:bg-error-container/5 transition-colors">
                <td class="px-lg py-md font-code text-code text-on-surface-variant">45</td>
                <td class="px-lg py-md">
                  <div class="font-label-md text-label-md text-on-surface">Juan Perez</div>
                  <div class="font-body-sm text-body-sm text-on-surface-variant">DNI: 20.345.678-X</div>
                </td>
                <td class="px-lg py-md">
                  <span class="inline-flex items-center gap-xs px-2 py-0.5 rounded-full bg-error-container text-on-error-container font-label-sm text-label-sm">
                    <span class="material-symbols-outlined text-[14px]">error</span> Error
                  </span>
                </td>
                <td class="px-lg py-md font-body-sm text-body-sm text-error font-medium">DNI Duplicado</td>
                <td class="px-lg py-md font-body-sm text-body-sm text-on-surface-variant italic">
                  Verificar registro existente o corregir dígito verificador en fila 45.
                </td>
                <td class="px-lg py-md">
                  <button class="p-2 text-primary hover:bg-primary/10 rounded-full transition-colors">
                    <span class="material-symbols-outlined">edit</span>
                  </button>
                </td>
              </tr>
              <tr class="hover:bg-tertiary-fixed/20 transition-colors">
                <td class="px-lg py-md font-code text-code text-on-surface-variant">120</td>
                <td class="px-lg py-md">
                  <div class="font-label-md text-label-md text-on-surface">maria garcia lopez</div>
                  <div class="font-body-sm text-body-sm text-on-surface-variant">ID: 88231</div>
                </td>
                <td class="px-lg py-md">
                  <span class="inline-flex items-center gap-xs px-2 py-0.5 rounded-full bg-tertiary-fixed text-on-tertiary-fixed-variant font-label-sm text-label-sm">
                    <span class="material-symbols-outlined text-[14px]">warning</span> Advertencia
                  </span>
                </td>
                <td class="px-lg py-md font-body-sm text-body-sm text-on-tertiary-fixed-variant">Nombre Mal Formateado</td>
                <td class="px-lg py-md font-body-sm text-body-sm text-on-surface-variant italic">
                  Usar formato Título (capitalizar nombres y apellidos).
                </td>
                <td class="px-lg py-md">
                  <button class="p-2 text-primary hover:bg-primary/10 rounded-full transition-colors">
                    <span class="material-symbols-outlined">auto_fix_high</span>
                  </button>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
        <div class="px-lg py-lg bg-surface-container-low flex justify-between items-center">
          <p class="font-body-sm text-body-sm text-on-surface-variant max-w-lg">
            <span class="font-bold">Nota:</span> Los registros con advertencias pueden importarse, pero se recomienda revisión para mantener la integridad de los datos.
          </p>
          <a
            href="/mapping"
            class="bg-primary text-on-primary px-2xl py-md rounded-lg font-headline-sm text-headline-sm shadow-lg hover:shadow-xl hover:scale-[1.02] active:scale-[0.98] transition-all flex items-center gap-md"
          >
            Continuar al Mapeo
            <span class="material-symbols-outlined">arrow_forward</span>
          </a>
        </div>
      </div>
    </section>

  </div>

</DashboardLayout>

<script>
  const dropZone = document.getElementById('drop-zone');
  if (dropZone) {
    ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(e =>
      dropZone.addEventListener(e, (ev) => { ev.preventDefault(); ev.stopPropagation(); })
    );
    ['dragenter', 'dragover'].forEach(e =>
      dropZone.addEventListener(e, () => {
        dropZone.classList.add('border-primary', 'bg-surface-container-low');
      })
    );
    ['dragleave', 'drop'].forEach(e =>
      dropZone.addEventListener(e, () => {
        dropZone.classList.remove('border-primary', 'bg-surface-container-low');
      })
    );
  }
</script>
