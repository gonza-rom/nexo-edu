---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Iniciar sesión">
  <div class="min-h-screen flex items-center justify-center p-md bg-[#f8fafc]">

    <main class="w-full max-w-[440px]">

      <!-- Logo -->
      <div class="flex flex-col items-center mb-xl">
        <div class="w-20 h-20 mb-md bg-white rounded-xl flex items-center justify-center shadow-sm border border-outline-variant">
          <!-- Reemplazar con el logo real de NexoEDU -->
          <span class="material-symbols-outlined text-primary text-[40px]">school</span>
        </div>
        <h1 class="font-headline-md text-headline-md text-primary mb-xs">NexoEDU</h1>
        <p class="font-body-sm text-body-sm text-on-surface-variant">Gestión Educativa Inteligente</p>
      </div>

      <!-- Card -->
      <div
        id="login-card"
        class="bg-surface-container-lowest border border-outline-variant p-xl rounded-xl shadow-[0_10px_15px_-3px_rgba(0,0,0,0.1),0_4px_6px_-2px_rgba(0,0,0,0.05)] opacity-0 translate-y-2.5"
      >
        <div class="space-y-lg">

          <!-- Tipo de perfil -->
          <div class="space-y-sm">
            <label class="font-label-md text-label-md text-on-surface">Tipo de Perfil</label>
            <div class="grid grid-cols-3 gap-sm">
              {['Administrador', 'Administrativo', 'Auditor'].map((role) => (
                <button
                  type="button"
                  data-role-btn
                  class="border border-outline-variant rounded-lg py-xs px-sm font-label-sm text-label-sm text-on-surface-variant hover:border-primary hover:text-primary transition-colors focus:ring-2 focus:ring-primary/20 outline-none"
                >
                  {role}
                </button>
              ))}
            </div>
          </div>

          <!-- Email -->
          <div class="space-y-sm">
            <label class="font-label-md text-label-md text-on-surface" for="email">
              Correo electrónico
            </label>
            <div class="relative group">
              <span class="material-symbols-outlined absolute left-md top-1/2 -translate-y-1/2 text-outline group-focus-within:text-primary transition-colors">
                mail
              </span>
              <input
                id="email"
                type="email"
                placeholder="nombre@institucion.edu"
                class="w-full pl-[44px] pr-md py-md border border-outline-variant rounded-lg bg-white font-body-md text-body-md focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all placeholder:text-outline-variant"
              />
            </div>
          </div>

          <!-- Contraseña -->
          <div class="space-y-sm">
            <div class="flex justify-between items-center">
              <label class="font-label-md text-label-md text-on-surface" for="password">
                Contraseña
              </label>
              <a href="#" class="font-label-sm text-label-sm text-primary hover:underline transition-all">
                Olvidé mi contraseña
              </a>
            </div>
            <div class="relative group">
              <span class="material-symbols-outlined absolute left-md top-1/2 -translate-y-1/2 text-outline group-focus-within:text-primary transition-colors">
                lock
              </span>
              <input
                id="password"
                type="password"
                placeholder="••••••••"
                class="w-full pl-[44px] pr-md py-md border border-outline-variant rounded-lg bg-white font-body-md text-body-md focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all placeholder:text-outline-variant"
              />
            </div>
          </div>

          <!-- Submit -->
          <div class="pt-sm">
            <button
              type="submit"
              class="w-full bg-primary text-white font-label-md text-label-md py-md px-lg rounded-lg shadow-sm hover:bg-surface-tint hover:shadow-md active:opacity-90 transition-all duration-200"
            >
              Iniciar sesión
            </button>
          </div>

        </div>
      </div>

      <!-- Footer -->
      <footer class="mt-xl text-center">
        <p class="font-body-sm text-body-sm text-on-surface-variant">
          ¿Necesitás soporte técnico?{' '}
          <a href="#" class="text-primary font-label-sm font-medium hover:underline">
            Contactar soporte
          </a>
        </p>
      </footer>

    </main>

    <!-- Decorative blobs -->
    <div class="fixed top-0 right-0 p-xl opacity-20 pointer-events-none" aria-hidden="true">
      <div class="w-64 h-64 bg-primary-container rounded-full blur-3xl"></div>
    </div>
    <div class="fixed bottom-0 left-0 p-xl opacity-10 pointer-events-none" aria-hidden="true">
      <div class="w-96 h-96 bg-secondary-container rounded-full blur-3xl"></div>
    </div>

  </div>
</BaseLayout>

<script>
  // Animación de entrada de la card
  const card = document.getElementById('login-card');
  if (card) {
    requestAnimationFrame(() => {
      card.style.transition = 'opacity 0.5s cubic-bezier(0.16,1,0.3,1), transform 0.5s cubic-bezier(0.16,1,0.3,1)';
      card.style.opacity = '1';
      card.style.transform = 'translateY(0)';
    });
  }

  // Selección de rol
  const roleBtns = document.querySelectorAll<HTMLButtonElement>('[data-role-btn]');
  roleBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      roleBtns.forEach((b) => {
        b.classList.remove('bg-primary-fixed', 'border-primary', 'text-primary');
        b.classList.add('border-outline-variant', 'text-on-surface-variant');
      });
      btn.classList.remove('border-outline-variant', 'text-on-surface-variant');
      btn.classList.add('bg-primary-fixed', 'border-primary', 'text-primary');
    });
  });
</script>
