---
interface Props {
  searchPlaceholder?: string;
  showActions?: boolean;
}

const { searchPlaceholder = 'Buscar registros o alumnos...', showActions = true } = Astro.props;
---

<header class="fixed top-0 right-0 w-[calc(100%-280px)] h-16 bg-surface border-b border-outline-variant flex justify-between items-center px-lg z-40">

  <!-- Search -->
  <div class="flex items-center gap-md flex-1">
    <div class="relative w-full max-w-md">
      <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-[20px]">search</span>
      <input
        type="text"
        placeholder={searchPlaceholder}
        class="w-full bg-surface-container-low border border-outline-variant rounded-lg pl-10 pr-4 py-2 font-label-md text-label-md focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all"
      />
    </div>
  </div>

  <!-- Actions -->
  <div class="flex items-center gap-md">
    {showActions && (
      <>
        <a
          href="/imports"
          class="bg-primary text-white px-md py-2 rounded-lg font-label-md text-label-md flex items-center gap-sm hover:brightness-110 transition-all shadow-sm"
        >
          <span class="material-symbols-outlined text-[18px]">add</span>
          Nueva Importación
        </a>
        <div class="h-8 w-px bg-outline-variant mx-sm"></div>
      </>
    )}
    <button class="relative p-2 text-on-surface-variant hover:text-primary transition-all" aria-label="Notificaciones">
      <span class="material-symbols-outlined">notifications</span>
      <span class="absolute top-2 right-2 w-2 h-2 bg-error rounded-full"></span>
    </button>
    <button class="p-2 text-on-surface-variant hover:text-primary transition-all" aria-label="Ayuda">
      <span class="material-symbols-outlined">help_outline</span>
    </button>
    <div class="h-8 w-px bg-outline-variant mx-sm"></div>
    <div class="w-8 h-8 rounded-full bg-primary-fixed-dim flex items-center justify-center text-secondary font-bold text-label-sm cursor-pointer">
      JD
    </div>
  </div>

</header>
